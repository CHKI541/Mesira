rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths} {
      // Allow anyone to view product images
      allow read: if true;
      
      // Allow writing/uploading only if the user is authenticated
      allow write: if request.auth != null;
      
      // Allow deletion only if the user is authenticated (can add check for seller ownership if storing metadata in file metadata, but simple auth check is standard for MVPs)
      allow delete: if request.auth != null;
    }
  }
}
