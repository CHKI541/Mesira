rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Allow anyone to read/view product images (public feed)
      allow read: if true;
      
      // Allow upload only if authenticated
      allow write: if request.auth != null;
      
      // Security fix #3: Allow deletion only if the authenticated user owns the file.
      // Files should be stored at path products/{userId}/{filename} for this to work.
      // Fallback: only allow deletion for authenticated users (MVP level security)
      allow delete: if request.auth != null && 
        (request.auth.token.email == 'israel.chueke@gmail.com' ||
         request.auth.token.email == 'eli2626cohen@gmail.com' ||
         request.auth.uid == resource.metadata["ownerId"] || 
         resource.metadata["ownerId"] == null);
    }
  }
}
