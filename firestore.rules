rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules — only the authenticated owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Product rules
    match /products/{productId} {
      // Allow reading products publicly (for the feed and detail pages)
      allow read: if true;
      
      // Allow creation only if the authenticated user is set as the seller
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid;
      
      // Allow update if:
      // 1. The authenticated seller is editing their own product (any field)
      // 2. An authenticated user is registering a contact (only contact-related fields)
      // 3. An authenticated user is registering a view (only view-related fields)
      //    Security fix #1: views now require auth to prevent bot inflation
      allow update: if (
        // Seller rule: full update rights on their own product
        (request.auth != null && resource.data.sellerId == request.auth.uid) ||
        
        // Contact registration rule: only contact-tracking fields can change, and count must increase by 1
        (request.auth != null && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contactCount', 'contactedUserIds', 'isActive', 'deactivatedAt']) &&
         request.resource.data.contactCount == resource.data.contactCount + 1) ||
         
        // View registration rule: only authenticated users can register views
        (request.auth != null &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'viewedUserIds']) &&
         request.resource.data.viewsCount == resource.data.viewsCount + 1)
      );
      
      // Allow delete only if the authenticated user is the seller
      allow delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
    }

    // Alert rules — users can only access their own alerts
    match /alerts/{alertId} {
      allow read, delete, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
