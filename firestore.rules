rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Product rules
    match /products/{productId} {
      // Allow reading products (both active and inactive) publicly
      allow read: if true;
      
      // Allow creation if the user is authenticated and is set as the seller
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid;
      
      // Allow update if:
      // 1. The user is the seller (they can edit anything)
      // 2. The user (authenticated) is registering a contact (only contact-related fields can change)
      // 3. Anyone (authenticated or guest) is registering a view (only view-related fields can change)
      allow update: if (
        // Seller rule
        (request.auth != null && resource.data.sellerId == request.auth.uid) ||
        
        // Contact registration rule
        (request.auth != null && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contactCount', 'contactedUserIds', 'isActive', 'deactivatedAt']) &&
         request.resource.data.contactCount == resource.data.contactCount + 1) ||
         
        // View registration rule
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'viewedUserIds']) &&
         request.resource.data.viewsCount == resource.data.viewsCount + 1)
      );
      
      // Allow delete only if the user is the seller
      allow delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
    }

    // Alert rules
    match /alerts/{alertId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
